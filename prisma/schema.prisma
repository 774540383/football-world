generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           String    @default("USER")
  favoriteTeam   String?
  favoriteLeague String?
  newsSubscribed Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  news      News[]
  comments  Comment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model League {
  id          String   @id @default(cuid())
  apiId       Int      @unique
  name        String
  nameAr      String?
  type        String   @default("league")
  logo        String?
  banner      String?
  country     String?
  countryFlag String?
  season      Int
  seasonEnd   String?
  standings   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches Match[]
  teams   Team[]
  seasons LeagueSeason[]

  @@map("leagues")
}

model LeagueSeason {
  id         String   @id @default(cuid())
  leagueId   String
  seasonYear Int
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, seasonYear])
  @@map("league_seasons")
}

model Team {
  id         String   @id @default(cuid())
  apiId      Int      @unique
  name       String
  nameAr     String?
  logo       String?
  banner     String?
  country    String?
  founded    Int?
  stadium    String?
  capacity   Int?
  coach      String?
  leagueId   String?
  league     League?  @relation(fields: [leagueId], references: [id])
  rating     Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  homeMatches  Match[]    @relation("HomeTeam")
  awayMatches  Match[]    @relation("AwayTeam")
  players      Player[]
  news         News[]
  standings    Standing[]

  @@map("teams")
}

model Player {
  id          String   @id @default(cuid())
  apiId       Int      @unique
  name        String
  nameAr      String?
  firstName   String?
  lastName    String?
  age         Int?
  nationality String?
  flag        String?
  photo       String?
  position    String?
  number      Int?
  height      String?
  weight      String?
  rating      Float    @default(0)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  goals         Int     @default(0)
  assists       Int     @default(0)
  appearances   Int     @default(0)
  yellowCards   Int     @default(0)
  redCards      Int     @default(0)
  minutesPlayed Int     @default(0)

  stats PlayerStat[]
  news  News[]

  @@map("players")
}

model PlayerStat {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id])
  leagueId  String?
  season    Int
  goals     Int      @default(0)
  assists   Int      @default(0)
  shots     Int      @default(0)
  shotsOnTarget Int  @default(0)
  passes    Int      @default(0)
  keyPasses Int      @default(0)
  tackles   Int      @default(0)
  interceptions Int  @default(0)
  fouls     Int      @default(0)
  offsides  Int      @default(0)
  saves     Int      @default(0)
  rating    Float    @default(0)
  createdAt DateTime @default(now())

  @@map("player_stats")
}

model Match {
  id         String   @id @default(cuid())
  apiId      Int      @unique
  leagueId   String?
  league     League?  @relation(fields: [leagueId], references: [id])
  round      String?
  status     String   @default("SCHEDULED")
  minute     Int      @default(0)
  homeTeamId String
  homeTeam   Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId String
  awayTeam   Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore  Int?
  awayScore  Int?
  homePenalty Int?
  awayPenalty Int?
  date       DateTime
  venue      String?
  referee    String?
  attendance Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  events      MatchEvent[]
  playerStats PlayerStat[]
  news        News[]

  @@index([status, date])
  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("matches")
}

model MatchStat {
  id            String @id @default(cuid())
  matchId       String
  teamSide      String @default("home")
  possession    Int    @default(50)
  shots         Int    @default(0)
  shotsOnTarget Int    @default(0)
  corners       Int    @default(0)
  fouls         Int    @default(0)
  yellowCards   Int    @default(0)
  redCards      Int    @default(0)
  offsides      Int    @default(0)
  saves         Int    @default(0)

  @@unique([matchId, teamSide])
  @@map("match_stats")
}

model MatchEvent {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamSide  String
  type      String
  player    String?
  playerId  Int?
  minute    Int
  extraMinute Int?
  assist    String?
  assistPlayer Int?
  detail    String?
  scoreHome Int?
  scoreAway Int?
  createdAt DateTime @default(now())

  @@index([matchId, minute])
  @@map("match_events")
}

model Standing {
  id        String @id @default(cuid())
  leagueId  String
  season    Int
  position  Int
  teamId    String
  team      Team   @relation(fields: [teamId], references: [id])
  played    Int    @default(0)
  won       Int    @default(0)
  drawn     Int    @default(0)
  lost      Int    @default(0)
  goalsFor  Int    @default(0)
  goalsAgainst Int @default(0)
  points    Int    @default(0)
  form      String?
  group     String?

  @@unique([leagueId, season, teamId])
  @@index([leagueId, season])
  @@map("standings")
}

model News {
  id        String   @id @default(cuid())
  title     String
  titleAr   String?
  slug      String   @unique
  excerpt   String?
  content   String
  image     String?
  category  String   @default("OTHER")
  tags      String?
  source    String?
  sourceUrl String?
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id])
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  playerId  String?
  player    Player?  @relation(fields: [playerId], references: [id])
  featured  Boolean  @default(false)
  published Boolean  @default(true)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]

  @@index([slug])
  @@index([category, createdAt])
  @@index([featured, published])
  @@map("news")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  newsId    String
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([newsId, createdAt])
  @@map("comments")
}

model Ad {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("banner")
  position  String   @default("sidebar")
  imageUrl  String?
  code      String?
  linkUrl   String?
  active    Boolean  @default(true)
  clicks    Int      @default(0)
  views     Int      @default(0)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ads")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String   @default("image")
  alt       String?
  width     Int?
  height    Int?
  size      Int?
  uploadedById String?
  createdAt DateTime @default(now())

  @@map("media")
}

